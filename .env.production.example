TMB_ENV=production
TMB_API_KEY=replace-with-a-random-64-character-secret
TMB_API_ROLE=admin
TMB_REQUIRE_SECURE_API_KEY=true

TMB_AI_PROVIDER=gemini
TMB_GEMINI_API_KEY=replace-with-gemini-api-key
TMB_GEMINI_MODEL=gemini-2.5-flash

TMB_DATABASE_URL=sqlite:///data/tmb_ai_os.db
TMB_APP_TIMEZONE=Asia/Bangkok

TMB_SCHEDULER_ENABLED=false
TMB_SCHEDULER_HOUR=8
TMB_SCHEDULER_MINUTE=0

TMB_RATE_LIMIT_REQUESTS=60
TMB_RATE_LIMIT_WINDOW_SECONDS=60

TMB_HOST=0.0.0.0
TMB_PORT=8000
TMB_WORKERS=1
